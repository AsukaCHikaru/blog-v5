{
  "compilerOptions": {
    "baseUrl": "./src",
    "jsx": "react-jsx",
    "target": "ES5",
    "module": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "moduleResolution": "node"
  },
  "include": ["src/*.ts", "src/*.tsx"],
  "exclude": ["**/node_modules/**"]
}